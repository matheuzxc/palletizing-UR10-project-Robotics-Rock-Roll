# ==========================================================================
# .gitignore — envia ao GitHub apenas o necessário (código-fonte + testes +
# docs do repo). Artefatos gerados, dados do operador e lixo de ambiente ficam de fora.
# ==========================================================================

# --- Python: bytecode e caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Ambientes virtuais ---
.venv/
venv/
env/
ENV/

# --- Empacotamento / build ---
build/
dist/
*.egg-info/
.eggs/

# --- Artefatos GERADOS pelo software (regeneráveis a partir das configs) ---
# URScript gerado. Se quiser versionar um palletizer_core.script como entregável,
# force com:  git add -f scripts/palletizer_core.script
scripts/
*.script

# --- Dados do operador (configs locais de paletização) ---
# A pasta é mantida no repo via configs/.gitkeep; os JSON de cada ambiente não vão.
configs/*.json

# --- Editores / IDEs ---
.vscode/
.idea/
*.swp
*~

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini
