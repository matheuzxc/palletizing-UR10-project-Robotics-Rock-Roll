# ==========================================================================
# .gitignore — envia ao GitHub apenas o necessário (código-fonte + README).
# Artefatos gerados, planos de trabalho, dados do operador e lixo de ambiente
# ficam de fora.
# ==========================================================================

# --- Planos de trabalho (artefatos internos, não fazem parte da entrega) ---
plans/

# --- Python: bytecode e caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Ambientes virtuais ---
.venv/
venv/
env/
ENV/

# --- Empacotamento / build ---
build/
dist/
*.egg-info/
.eggs/

# --- Editores / IDEs ---
.vscode/
.idea/
*.swp
*~

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini
